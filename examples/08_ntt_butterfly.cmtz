-- 08_ntt_butterfly.cmtz
--
-- One radix-2 NTT butterfly step over F_17.
--
-- The Number-Theoretic Transform butterfly is:
--   (a, b)  â†’  (a + Ď‰^k Â· b,  a - Ď‰^k Â· b)
--
-- This is the core operation in NTT-based polynomial multiplication,
-- used in post-quantum cryptography (Kyber/Dilithium) and ZK-SNARK
-- proof systems.  All arithmetic is exact â€” no floating point.
--
-- Root table: g=3 is a primitive root of F_17.
--   Ď‰^0=1, Ď‰^1=3, Ď‰^2=9, Ď‰^3=10, Ď‰^4=13, Ď‰^5=5, ...
--   Ď‰^8=16 (=-1), Ď‰^15=6.
--
-- Here:
--   a = Ď‰^0 = 1            (embed_0)
--   b = Ď‰^3 = 10           (embed_1)
--   twiddle k = 4, so Ď‰^4 = 13
--
--   Ď‰^k Â· b = rotate(b, k) = 10 Â· 13 = 130 mod 17 = 11
--
--   wing_plus  = a + Ď‰^kÂ·b = 1 + 11 = 12 mod 17
--   wing_minus = a - Ď‰^kÂ·b = 1 - 11 = -10 â‰ˇ 7 mod 17
--
-- Subtraction: since Ď‰^(m/2) = Ď‰^8 = -1 mod 17, we compute -x as
-- rotate(x, 8), i.e. multiply by Ď‰^8 = 16 â‰ˇ -1.
--
--   -(Ď‰^kÂ·b) = 11 Â· 16 = 176 mod 17 = 6
--   wing_minus = 1 + 6 = 7 mod 17  âś“

field(17, 19);
roots(17) as omega;

-- Input pair
embed(0, 0);            -- a = Ď‰^0 = 1
embed(1, 3);            -- b = Ď‰^3 = 10

-- Twiddle: multiply b by Ď‰^4
rotate(embed_1, twiddle_b, 4);          -- Ď‰^3 Â· Ď‰^4 = Ď‰^7 = 12

-- Plus wing: a + Ď‰^k Â· b
add(embed_0, rot_embed_1_twiddle_b) as wing_plus;    -- 1 + 11 = 12

-- Negate twiddle via half-turn: multiply by Ď‰^8 = -1 mod 17
rotate(rot_embed_1_twiddle_b, neg_tw, 8);   -- 11 Â· 16 = 6

-- Minus wing: a + (-Ď‰^k Â· b) = a - Ď‰^k Â· b
add(embed_0, rot_rot_embed_1_twiddle_b_neg_tw) as wing_minus;   -- 1 + 6 = 7

measure(wing_plus, mod_p) as out_plus;       -- expect 12
measure(wing_minus, mod_p) as out_minus;     -- expect 7
